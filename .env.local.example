# NextAuth
AUTH_SECRET=                    # generate with: openssl rand -base64 32
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=
AUTH_GITHUB_ID=
AUTH_GITHUB_SECRET=

# Supabase — server-only access (secret key bypasses RLS)
# Never use NEXT_PUBLIC_ prefix for these — they must stay on the server
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SECRET_KEY=sb_secret_...

# Direct connection URL (port 5432) — used by drizzle-kit for migrations only
DATABASE_DIRECT_URL=postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:5432/postgres
